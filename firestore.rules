rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    function userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    // Acepta activo como booleano o como texto, porque algunos usuarios antiguos
    // pueden haber quedado guardados como "true", "si", "sí", "activo", etc.
    function activeValue() {
      return signedIn() ? userDoc().data.activo : false;
    }

    function activeUser() {
      return signedIn() && (
        activeValue() == true ||
        activeValue() in ["true", "True", "TRUE", "si", "Si", "SI", "sí", "Sí", "SÍ", "activo", "Activo", "ACTIVO", "1"]
      );
    }

    function role() {
      return activeUser() ? (userDoc().data.rol) : "none";
    }

    // Acepta roles antiguos/nuevos y variantes en español.
    function isEditor() {
      return role() in [
        "editor", "Editor", "EDITOR",
        "admin", "Admin", "ADMIN",
        "administrador", "Administrador", "ADMINISTRADOR",
        "superadmin", "Superadmin", "SUPERADMIN"
      ];
    }

    function isAdmin() {
      return role() in [
        "admin", "Admin", "ADMIN",
        "administrador", "Administrador", "ADMINISTRADOR",
        "superadmin", "Superadmin", "SUPERADMIN"
      ];
    }

    function isSuperadmin() {
      return role() in ["superadmin", "Superadmin", "SUPERADMIN"];
    }

    // Usuarios: cada uno puede leer y actualizar solo su perfil de discursante.
    // Admin puede editar cualquier perfil y superadmin puede borrar el documento completo.
    function selfProfileFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "nombre", "nombreCompleto", "email",
        "telefono", "telefonoPerfil",
        "responsabilidad", "privilegio",
        "congregacionPerfil", "congregacion",
        "perfilBosquejos", "bosquejosPerfil",
        "discursosTiene", "discursosQuierePreparar",
        "observacionesPerfil", "perfilDiscursante",
        "perfilActualizadoEn", "updatedAt"
      ]);
    }

    function selfCreateProfileFieldsOnly() {
      return request.resource.data.keys().hasOnly([
        "nombre", "nombreCompleto", "email",
        "telefono", "telefonoPerfil",
        "responsabilidad", "privilegio",
        "congregacionPerfil", "congregacion",
        "perfilBosquejos", "bosquejosPerfil",
        "discursosTiene", "discursosQuierePreparar",
        "observacionesPerfil", "perfilDiscursante",
        "perfilActualizadoEn", "updatedAt"
      ]);
    }

    match /usuarios/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isAdmin() || (signedIn() && request.auth.uid == uid && selfCreateProfileFieldsOnly());
      allow update: if isAdmin() || (signedIn() && request.auth.uid == uid && selfProfileFieldsOnly());
      allow delete: if isSuperadmin();
    }

    // Personas, asignaciones, visitas: lectura para usuarios activos; escritura para editores/admins.
    match /personas/{id} {
      allow read: if activeUser();
      allow write: if isEditor();
    }

    match /asignaciones/{id} {
      allow read: if activeUser();
      allow write: if isEditor();
    }

    // Asignaciones mensuales para tablero.
    match /asignaciones_mensuales/{id} {
      allow read: if activeUser() || request.auth == null;
      allow write: if isEditor();
    }

    match /visitas/{id} {
      allow read: if activeUser();
      allow write: if isEditor();
    }

    // Conferenciantes locales y turnos internos de suplencia.
    match /conferenciantesLocales/{id} {
      allow read: if activeUser();
      allow write: if isEditor();
    }

    match /suplenciasDiscursantes/{id} {
      allow read: if activeUser();
      allow write: if isEditor();
    }

    // Hospitalidad: config de rotación y excepciones por fecha.
    match /hospitalidad_config/{id} {
      allow read: if activeUser();
      allow write: if isEditor();
    }

    match /hospitalidad_excepciones/{id} {
      allow read: if activeUser();
      allow write: if isEditor();
    }

    match /salientes/{id} {
      allow read: if activeUser() || request.auth == null;
      allow write: if isEditor();
    }

    // Catálogos: solo lectura a activos; escritura admin.
    match /discursos/{id} {
      allow read: if activeUser();
      allow write: if isAdmin();
    }
    match /canciones/{id} {
      allow read: if activeUser();
      allow write: if isAdmin();
    }
  }
}
